rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function validString(field) { return field is string && field.size() > 0; }
    function validPositiveNumber(field) { return field is number && field >= 0; }

    match /{document=**} { allow read, write: if false; }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.uid == request.auth.uid && validString(request.resource.data.email) && request.resource.data.role == 'client';
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email', 'role', 'createdAt']);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin() && request.auth.uid != adminId;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && validString(request.resource.data['service']) && validString(request.resource.data.date) && validString(request.resource.data.time) && request.resource.data.status == 'pending' && validPositiveNumber(request.resource.data.price);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['price', 'finalPrice', 'discountApplied', 'status', 'professional', 'userId']));
      allow delete: if isAdmin();
    }

    match /designs/{designId} {
      allow read: if resource.data.isPublic == true || (isSignedIn() && resource.data.creatorId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid && validString(request.resource.data.imageUrl) && request.resource.data.isPublic is bool;
      allow update: if (isSignedIn() && resource.data.creatorId == request.auth.uid && request.resource.data.creatorId == request.auth.uid) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.creatorId == request.auth.uid) || isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && validString(request.resource.data.code) && validPositiveNumber(request.resource.data.discount) && request.resource.data.isActive is bool;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
