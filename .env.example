# ─── NUNCA commitees el .env real al repositorio ───────────────────────────
#
# Copiá este archivo como .env y completá los valores.
# El .env está en .gitignore — verificá que así sea antes de hacer push.
#
# En Vercel: cargá estas variables en Settings → Environment Variables.
# En local:  el archivo .env las inyecta automáticamente via Vite / dotenv.

# Clave de Gemini AI — SOLO se usa en el servidor (api/gemini.ts)
# NUNCA la expongas en el cliente ni en vite.config.ts define{}
GEMINI_API_KEY="tu_clave_aqui"

# URL base del app (se inyecta automáticamente en Vercel)
APP_URL="https://lupenails.vercel.app"
